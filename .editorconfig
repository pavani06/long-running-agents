# EditorConfig — https://editorconfig.org/
# Enforces project-wide formatting conventions.
# Issue: #980 (FUP-964)

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
